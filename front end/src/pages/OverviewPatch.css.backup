/* LAYOUT FIX - Masonry Grid */
.overview__ai-assistant-hero {
  grid-column: 1 / 3 !important;
  grid-row: 1 !important;
  max-width: 100% !important;
  margin: 0 !important;
  width: 100% !important;
}

.sidebar-section--day-glance {
  grid-column: 3 !important;
  grid-row: 1 / span 10 !important;
}

/* HAZEL.AI STYLE - Single Rounded Rectangle Container */
.overview__ai-assistant-hero .ai-assistant-input-wrapper {
  position: relative !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 0 !important;
  padding: 1.25rem !important;
  padding-bottom: 4.5rem !important;
  background: #ffffff !important;
  border: 1px solid var(--success) !important;
  border-radius: 16px !important;
  transition: all var(--transition-base) !important;
  margin-bottom: var(--space-xl) !important;
  min-height: 180px !important;
}
