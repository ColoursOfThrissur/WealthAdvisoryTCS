.overview {
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  padding: 60px var(--space-2xl) var(--space-2xl) var(--space-2xl);
  position: relative;
}

.overview__content {
  display: grid;
  grid-template-columns: 35% 35% 30%;
  gap: var(--space-lg);
  transition: opacity 0.3s ease, transform 0.3s ease;
  grid-auto-flow: dense;
  align-items: start;
  width: 100%;
  max-width: 100%;
}

/* AI Assistant Hero - 70% Width */
.overview__ai-assistant-hero {
  grid-column: 1 / 3;
  grid-row: 1;
  background: var(--bg-secondary);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  width: 100%;
  max-width: 100%;
  height: auto;
  align-self: start;
  overflow: hidden;
}
